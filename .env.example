# ── REQUIRED — set these in Railway dashboard ─────────────────────────────────

# Strong random secret for JWT signing
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Your Gmail address
EMAIL_ADDRESS=mzoraofficial@gmail.com

# Gmail App Password (NOT your real Gmail password)
# Get from: Google Account > Security > App Passwords
EMAIL_APP_PASSWORD=your-app-password-here

# SQLite DB path — set this to Railway volume mount path
DATABASE_URL=sqlite:////data/users.db

# ── OPTIONAL ──────────────────────────────────────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
IMAP_SERVER=imap.gmail.com
MAILBOX_FETCH_LIMIT=20
AUTO_REPLY=false
AUTO_REPLY_POLL_INTERVAL=30
AUTO_REPLY_SEARCH_CRITERIA=UNSEEN
SEND_DELAY=0.5
BATCH_SIZE=1000
